{
  "name": "swingiq",
  "version": "1.0.0",
  "private": true,
  "description": "SwingIQ — Web-based AI golf performance platform (mobile-optimized)",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@swingiq/web",
    "dev:web": "turbo run dev --filter=@swingiq/web",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rimraf node_modules",
    "scan:placeholders": "node scripts/scan-placeholders.mjs",
    "check:trust": "npm run scan:placeholders",
    "validate:seo": "node scripts/validate-seo.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:links": "node scripts/validate-links.mjs",
    "generate:sitemap": "node scripts/check-sitemap.mjs",
    "growth:report": "node scripts/growth-report.mjs",
    "growth:plan": "node scripts/growth-plan.mjs",
    "audit:growth": "node scripts/audit-growth.mjs",
    "security:deps": "npm audit --audit-level=critical",
    "security:secrets": "echo 'Run: docker run --rm -v $(pwd):/repo zricethezav/gitleaks:latest detect --source=/repo'",
    "security:check": "node scripts/security-check.mjs",
    "security:all": "npm run security:deps && npm run security:check",
    "ci": "npm run type-check && npm run security:all"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.18",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=18.0.0"
  }
}
