{
  "name": "swingiq",
  "version": "1.0.0",
  "private": true,
  "description": "SwingVantage — Web-based AI golf performance platform (mobile-optimized)",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@swingiq/web",
    "dev:web": "turbo run dev --filter=@swingiq/web",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rimraf node_modules",
    "scan:placeholders": "node scripts/scan-placeholders.mjs",
    "check:trust": "npm run scan:placeholders",
    "check:naming": "node scripts/check-naming.mjs",
    "validate:seo": "node scripts/validate-seo.mjs",
    "check:duplicate-content": "node scripts/check-duplicate-content.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:links": "node scripts/validate-links.mjs",
    "generate:sitemap": "node scripts/check-sitemap.mjs && node scripts/check-sitemap-coverage.mjs",
    "check:sitemap:coverage": "node scripts/check-sitemap-coverage.mjs",
    "generate:brand": "node scripts/generate-brand-assets.mjs",
    "updates:generate": "node scripts/generate-updates.mjs",
    "test:scripts": "node --test \"scripts/__tests__/**/*.test.mjs\"",
    "docs:index": "node scripts/build-docs-index.mjs",
    "docs:admin-guide:capture": "node scripts/admin-guide/capture.mjs",
    "docs:admin-guide:build": "python scripts/admin-guide/build-pdf.py",
    "features:scan": "node scripts/scan-features.mjs",
    "setup:scan": "node scripts/scan-setup.mjs",
    "scan:branches": "node scripts/scan-branches.mjs",
    "social:queue": "node scripts/generate-social-queue.mjs",
    "hooks:install": "node scripts/install-hooks.mjs",
    "growth:report": "node scripts/growth-report.mjs",
    "growth:plan": "node scripts/growth-plan.mjs",
    "audit:growth": "node scripts/audit-growth.mjs",
    "i18n:upkeep": "node scripts/i18n/upkeep.mjs",
    "i18n:bless": "node scripts/i18n/upkeep.mjs --bless",
    "i18n:translate": "node scripts/i18n/upkeep.mjs --translate --bless",
    "security:deps": "npm audit --audit-level=critical",
    "security:secrets": "echo 'Run: docker run --rm -v $(pwd):/repo zricethezav/gitleaks:latest detect --source=/repo'",
    "security:check": "node scripts/security-check.mjs",
    "security:all": "npm run security:deps && npm run security:check",
    "ci": "npm run type-check && npm run check:naming && npm run security:all"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^6.0.0",
    "rimraf": "^6.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0"
  },
  "//overrides": "Security: force patched transitive deps. minimatch (ReDoS) pinned >=9 globally; but eslint-plugin-jsx-a11y relies on minimatch's older callable default export, so it gets the patched 3.1.2 (>=3.0.5, ReDoS-safe) via a scoped override. postcss (XSS via next build tooling). All build/dev-time only.",
  "overrides": {
    "minimatch": "^9.0.5",
    "eslint-plugin-jsx-a11y": {
      "minimatch": "^3.1.2"
    },
    "postcss": "^8.5.10"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=18.0.0"
  }
}
