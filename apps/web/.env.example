# ============================================================
# SwingIQ Web App — Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Make a copy of this file and name the copy:  .env.local
#   2. Fill in the values below with your Supabase project details
#   3. Never share or commit your .env.local file
# ============================================================

# Supabase Project URL
# Found in: Supabase Dashboard → Your Project → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (safe to expose in browser)
# Found in: Supabase Dashboard → Your Project → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (KEEP SECRET — only used server-side)
# Found in: Supabase Dashboard → Your Project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used for redirects after login)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI Coach (optional) ──────────────────────────────────────
# The AI Coach works without a key — it returns data-grounded placeholder
# responses. To enable real AI responses, set one of the following:
#
# Option A — OpenAI:
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=sk-your-key-here
#   Get a key at: https://platform.openai.com/api-keys
#
# Option B — Anthropic (Claude):
#   AI_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-your-key-here
#   Get a key at: https://console.anthropic.com
#
# Leave AI_PROVIDER unset (or set to "none") to use placeholder mode.

AI_PROVIDER=none
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional: override the AI model used for coaching responses
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── AI Visual Analysis (swing video) ─────────────────────────
# Powers REAL AI vision analysis of uploaded swing videos. The app
# extracts still frames in the browser and sends ONLY those frames to
# the provider below. Without a key, the analyzer clearly shows
# "AI visual analysis is not currently configured" and never fabricates
# feedback.
#
# Choose ONE provider and set its key. Anthropic is the documented default.
#   anthropic | openai | google
AI_VISION_PROVIDER=anthropic
#
# Reuses the same keys as the AI Coach above where applicable:
#   Anthropic:  ANTHROPIC_API_KEY   (https://console.anthropic.com)
#   OpenAI:     OPENAI_API_KEY      (https://platform.openai.com/api-keys)
#   Google:     GOOGLE_AI_API_KEY   (https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=your-google-ai-key-here
#
# Optional model override (defaults: claude-3-5-sonnet-20241022 / gpt-4o / gemini-1.5-flash)
# AI_VISION_MODEL=claude-3-5-sonnet-20241022
#
# Optional (OpenAI only): image fidelity vs. cost — auto | low | high. Default auto.
# Set to "low" to cut token cost (frames are already downscaled).
# AI_VISION_IMAGE_DETAIL=auto
#
# Optional limits (sensible defaults are applied if unset)
# MAX_VIDEO_FRAMES_ANALYZED=16   # frames sampled across the clip (max 24)
# MAX_VIDEO_UPLOAD_MB=500
# MAX_VIDEO_DURATION_SECONDS=300

# ── Admin & Cron Security ────────────────────────────────────
# ADMIN_SECRET: protects /admin/* pages and /api/research/* endpoints.
#   Set to a long random string (32+ chars). Keep server-side only.
#   Generate one with: openssl rand -hex 32
ADMIN_SECRET=change-me-use-openssl-rand-hex-32

# CRON_SECRET: used by Vercel Cron jobs to trigger /api/research/run.
#   Must match the value configured in vercel.json cron Authorization header.
#   Generate with: openssl rand -hex 32
CRON_SECRET=change-me-use-openssl-rand-hex-32

# ── Research Workflow ────────────────────────────────────────
# Set to "true" to auto-approve low-risk benchmark proposals from research runs.
# Leave unset or "false" to require manual admin review for all proposals.
RESEARCH_AUTO_APPROVE_LOW_RISK=false
