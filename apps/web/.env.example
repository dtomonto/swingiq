# ============================================================
# SwingVantage Web App — Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Make a copy of this file and name the copy:  .env.local
#   2. Uncomment + fill in only the values for features you want to enable.
#   3. Never share or commit your .env.local file (it is gitignored).
#
# EVERYTHING IS OPTIONAL. SwingVantage runs fully without any keys —
# every integration below degrades to a safe, local-first default
# (local profile instead of accounts, data-grounded placeholder
# coaching instead of live AI, manual entry instead of OCR, a
# waitlist instead of real checkout, console logging instead of
# analytics). A key simply unlocks the matching upgrade.
#
# SAFE BY DEFAULT: this file is written so that copying it verbatim to
# .env.local enables NOTHING — every provider toggle defaults to "none"
# and every secret line is commented out. Uncomment a section only when
# you have a real key for it.
# ============================================================

# ── Keys & Secrets vault (optional) ──────────────────────────
# Unlocks the /admin/integrations Keys & Secrets manager — add/remove API keys
# from the dashboard (encrypted at rest, AES-256-GCM). Without it the manager
# stays read-only (detection + status only) and keys must be set as env vars
# below. Set this to a 32-byte base64 string (the dashboard can generate one).
# Run apps/web/supabase-secrets.sql once to create the encrypted store table.
# SECRETS_ENCRYPTION_KEY=your-32-byte-base64-master-key

# ── PublishingOS deploy-backed PR executor (optional) ────────
# Lets the admin promote a publish decision into a reviewable GitHub PR
# (committed override manifest). Keyless-safe: with no token the executor reports
# "not configured" and never writes. Manage these in the Keys & Secrets dashboard
# too. The token needs `repo` + pull-request write scope.
# GITHUB_TOKEN=ghp_your-token   # or github_pat_...
# GITHUB_REPO=owner/repo
# GITHUB_DEFAULT_BRANCH=master

# ── Supabase: accounts + cloud sync (optional) ───────────────
# Without these, SwingVantage uses a local, device-only profile.
# Found in: Supabase Dashboard → Your Project → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Anonymous key — safe to expose in the browser.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service Role key — KEEP SECRET, server-side only. Never prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Site / App URLs ──────────────────────────────────────────
# Canonical public URL — used for SEO metadata, sitemaps, and absolute
# links in structured data. Set to your production domain when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# App URL — used for redirects after login and Stripe checkout return.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI Coach (optional) ──────────────────────────────────────
# The AI Coach works without a key — it returns data-grounded placeholder
# responses. To enable real AI responses, set AI_PROVIDER and the matching
# key below.
#   none | openai | anthropic
AI_PROVIDER=none
# OpenAI:    https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here
# Anthropic: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
#
# Optional model overrides:
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-haiku-4-5

# ── AI Visual Analysis (swing video) ─────────────────────────
# Powers REAL AI vision analysis of uploaded swing videos. The app
# extracts still frames in the browser and sends ONLY those frames to
# the provider below. With the default "none", the analyzer clearly shows
# "AI visual analysis is not currently configured" and never fabricates
# feedback.
#
# Set ONE provider and its key (reuses the AI Coach keys above where
# applicable). Falls back to AI_PROVIDER if left as "none".
#   none | anthropic | openai | google
AI_VISION_PROVIDER=none
# Anthropic: ANTHROPIC_API_KEY    OpenAI: OPENAI_API_KEY (set above)
# Google:    https://aistudio.google.com/app/apikey
# GOOGLE_AI_API_KEY=your-google-ai-key-here
#
# Speed tier — the biggest lever on how long a review takes. "fast" uses a
# quicker model + concise output; "thorough" uses the larger model + full
# detail. The analyzer UI lets users pick per-analysis; this sets the default.
#   fast | balanced | thorough   (default fast)
#   fast     → claude-haiku-4-5 / gpt-4o-mini / gemini-1.5-flash
#   balanced → claude-sonnet-4-6 / gpt-4o      / gemini-1.5-flash
#   thorough → claude-sonnet-4-6 / gpt-4o      / gemini-1.5-pro
# AI_VISION_SPEED=fast
#
# Optional model override — pins ONE model for every tier (advanced).
# AI_VISION_MODEL=claude-sonnet-4-6
#
# Optional (OpenAI only): image fidelity vs. cost — auto | low | high.
# Overrides the tier's detail. Default follows the speed tier.
# AI_VISION_IMAGE_DETAIL=auto
#
# Optional limits (sensible defaults are applied if unset). The browser samples
# ~10 lean frames by default; this is the SERVER-SIDE CAP on how many it will
# accept for AI vision analysis (default 16, hard-max 24). Raise it only if you
# also raise the client sample count, to trade speed for detail.
# MAX_VIDEO_FRAMES_ANALYZED=16   # server cap on analyzed frames (hard-max 24)
# MAX_VIDEO_UPLOAD_MB=500
# MAX_VIDEO_DURATION_SECONDS=300

# ── OCR: launch-monitor image import (optional) ──────────────
# Reads the numbers off a photo of a launch-monitor / stats screen so you
# don't have to type them. With the default "none" the importer uses manual
# entry. Either way every extracted value requires user review before save.
#
# OCR reuses any vision-capable AI key you already configured: it tries
# OCR_PROVIDER first, then falls back to AI_VISION_PROVIDER, then AI_PROVIDER.
# So if AI vision is already enabled above, photo import works with no extra
# setup. Keys reuse the ones above (ANTHROPIC_API_KEY / OPENAI_API_KEY /
# GOOGLE_AI_API_KEY — the Google path is Gemini, not Cloud Vision).
#   none | anthropic | openai | google
OCR_PROVIDER=none
# Optional model override (else falls back to AI_VISION_MODEL, then a default):
# OCR_MODEL=gpt-4o

# ── Email capture / lifecycle email (optional) ───────────────
# Without any of these, leads are accepted but reported as not persisted
# (the API returns persisted:false) — no email is stored or sent.
# Uncomment exactly ONE provider's variables:
#
# Option A — Resend:
# RESEND_API_KEY=your-resend-key-here
# RESEND_AUDIENCE_ID=your-resend-audience-id-here
#
# Option B — ConvertKit:
# CONVERTKIT_API_KEY=your-convertkit-key-here
# CONVERTKIT_FORM_ID=your-convertkit-form-id-here
#
# Option C — Mailchimp:
# MAILCHIMP_API_KEY=your-mailchimp-key-here
# MAILCHIMP_LIST_ID=your-mailchimp-list-id-here
# MAILCHIMP_SERVER_PREFIX=usX
#
# Option D — generic webhook (POSTs the lead JSON to your endpoint):
# EMAIL_CAPTURE_WEBHOOK_URL=https://your-webhook-endpoint.example.com/leads

# ── Contact form → your inbox (optional) ─────────────────────
# Powers the /contact page. With RESEND_API_KEY set (same key as above),
# submissions are emailed to you with the sender's address as reply-to.
# Without a key, the form is honest: it tells the visitor the message was
# NOT sent and shows the direct support email instead.
#
# Where contact messages are delivered. Defaults to the public support@
# role address from config/site.ts (point that address at your real inbox).
# Set this to override it (e.g. a dedicated inbox). Keep your PRIVATE email
# out of the repo — use a forwarding role address here.
# CONTACT_TO_EMAIL=support@swingvantage.com
# From address for the notification (must be a Resend-verified sender):
# CONTACT_FROM_EMAIL=SwingVantage <noreply@swingvantage.com>

# ── Stripe: paid Pro/Team tiers (optional) ───────────────────
# Without keys, paid plans show a waitlist and NO charge can ever happen.
# Get keys at: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key-here
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key-here
# Webhook signing secret (https://dashboard.stripe.com/webhooks):
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here
# Price IDs for each paid tier (Stripe Dashboard → Products → Prices):
# STRIPE_PRICE_PRO=price_your-pro-price-id-here
# STRIPE_PRICE_TEAM=price_your-team-price-id-here

# ── Ads: Phase 2 monetization (optional, OFF by default) ─────
# SwingVantage's monetization order is: grow free users → ADS (first revenue) →
# membership tiers (see docs/MONETIZATION_STRATEGY.md). Ads are the first
# revenue step and stay OFF until you set BOTH values below — with them unset
# the app renders ZERO ads (the clean free experience).
#
# Turn this on only AFTER you have a steady, returning audience. Because
# SwingVantage has junior athletes, keep ads NON-PERSONALIZED / contextual for
# youth-safety (COPPA/GDPR-K) — get a compliance read before enabling.
#   none | adsense | <your-network>
# NEXT_PUBLIC_ADS_PROVIDER=none
# Ad-network account/client id (e.g. AdSense ca-pub-XXXXXXXX). Safe in browser.
# NEXT_PUBLIC_ADS_CLIENT_ID=your-ads-client-id-here

# ── Analytics (optional) ─────────────────────────────────────
# Without any of these, events log to the browser console only.
# Uncomment whichever provider you use (any one is enough). All three load
# only when their variable is set, auto-track page views (including in-app
# navigation), and receive SwingVantage's custom events.
#
# RECOMMENDED: Plausible — cookieless & privacy-first, so it needs NO cookie-
# consent banner and fits SwingVantage's youth-safe positioning. Set it to your
# production domain (the value you registered in Plausible).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=swingvantage.com
# Google Analytics 4 (sets cookies — pair with a consent banner in the EU):
# NEXT_PUBLIC_GA_ID=G-your-ga-measurement-id
# PostHog product analytics (host defaults to https://us.i.posthog.com):
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key-here
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Microsoft Clarity heatmaps & session replay — find the Project ID in the
# Clarity dashboard (Settings → Overview). NOTE: records sessions & sets
# cookies, so pair with a consent banner in the EU (unlike cookieless Plausible).
# NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id
# Clarity Data Export API token — OPTIONAL, powers LIVE metrics inside
# /admin/clarity (traffic, engagement, rage/dead clicks, script errors).
# Generate at Clarity → Settings → Data export. SERVER-SIDE secret (no
# NEXT_PUBLIC_ prefix). Clarity caps this API at ~10 calls/day, last 1–3 days.
# CLARITY_DATA_EXPORT_TOKEN=your-clarity-data-export-token
#
# Analytics OS (optional) — turns on LIVE numbers + feature-flag management
# inside /admin/analytics. SERVER-SIDE ONLY (never prefix with NEXT_PUBLIC_).
# Personal API key: PostHog → Settings → Personal API keys (read; add
# "Feature flag write" to toggle flags from the OS). Project ID: Settings → Project.
# POSTHOG_PERSONAL_API_KEY=phx_your-personal-api-key
# POSTHOG_PROJECT_ID=12345

# ── Google Search Console verification (optional) ────────────
# Lets you verify the site in Search Console with a meta tag (the simplest
# method) so you can submit /sitemap.xml and watch your search traffic grow.
# In GSC choose the "HTML tag" verification option and paste ONLY the token
# from its content="..." value below.
# NEXT_PUBLIC_GSC_VERIFICATION=your-google-site-verification-token

# ── ConnectorOS — additional connectors (all OPTIONAL, OFF by default) ──
# Unified connector layer. Status of every item below is shown in
# Admin → System Health / ConnectorOS. Full docs: docs/connector-os/.
#
# Bing Webmaster verification (mirror of GSC; paste only the token):
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-site-verification-token
#
# IndexNow — instant URL submission to Bing/Yandex when pages change.
# Host the key at https://<your-site>/<INDEXNOW_KEY>.txt (the file just
# contains the key). SERVER-ONLY. Keyless: submission no-ops.
# INDEXNOW_KEY=your-indexnow-key-uuid-like-string
# Optional override of the key-file URL (defaults to /<key>.txt):
# INDEXNOW_KEY_LOCATION=https://your-site/your-indexnow-key.txt
#
# Sentry — error monitoring. The observability reporter (lib/observability)
# is already wired and will start delivering once a DSN is set AND the SDK
# is installed/initialised (see docs/OBSERVABILITY.md). DSN is public by design.
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Source-map upload (CI only — SERVER-SIDE secret, never commit):
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
#
# Vercel Analytics / Speed Insights — installed; default ON. Set "false" to disable.
# NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=true
# NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS_ENABLED=true
#
# Cloudflare Turnstile — bot protection on public forms. Server verify only;
# keyless-safe (forms work without it, never blocks local dev).
# NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=your-turnstile-site-key
# CLOUDFLARE_TURNSTILE_SECRET_KEY=your-turnstile-secret-key
#
# MediaPipe on-device pose — already on-device by default. Set "false" to force off.
# NEXT_PUBLIC_MEDIAPIPE_ENABLED=true
#
# Optional: self-host the MediaPipe WASM runtime + pose models instead of the
# default public CDNs (jsdelivr + Google Storage). Point these at a same-origin
# path that MIRRORS the CDN layout — e.g. copy the package's `wasm/` dir and the
# `pose_landmarker_{lite,full,heavy}/float16/1/*.task` files under /public. Gives
# offline resilience, no third-party fetch, and a tighter CSP. Inference is
# on-device either way.
# NEXT_PUBLIC_MEDIAPIPE_WASM_BASE=/mediapipe/wasm
# NEXT_PUBLIC_MEDIAPIPE_MODEL_BASE=/mediapipe/models/pose_landmarker
#
# Mux — production video upload/playback (scaffold; SERVER-ONLY secrets):
# MUX_TOKEN_ID=your-mux-token-id
# MUX_TOKEN_SECRET=your-mux-token-secret
# MUX_WEBHOOK_SECRET=your-mux-webhook-secret
# NEXT_PUBLIC_MUX_PLAYBACK_SIGNING_KEY_ID=your-mux-playback-signing-key-id
# MUX_PLAYBACK_SIGNING_PRIVATE_KEY=your-mux-playback-private-key
#
# Cloudinary — image/media optimization (scaffold; SERVER-ONLY secrets):
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── AI Agents layer (optional) ───────────────────────────────
# The deterministic agent layer always runs locally. Set this to allow the
# optional LLM "enhance" pass (warmer phrasing of already-grounded text).
#   none → deterministic only (default)
# NEXT_PUBLIC_AGENTS_LLM=none

# ── Motion Lab cloud pose (optional, OFF by default) ─────────
# Motion Lab runs pose detection ON-DEVICE by default — frames never leave the
# browser. Set this ONLY if you want to route pose estimation to a cloud model
# instead (cloudPoseProvider). Enabling it means frames ARE POSTed to this
# endpoint, so it's an explicit privacy trade-off. Output stays "estimated"
# (a single camera is never a lab measurement). Leave unset to stay on-device.
# NEXT_PUBLIC_POSE_CLOUD_URL=https://your-pose-endpoint.example.com/infer

# ── Rate limiting (recommended once deployed) ────────────────
# API routes are rate-limited out of the box using in-memory counters.
# On Vercel each serverless instance has its own memory, so those limits
# only hold per-instance. To enforce limits across ALL instances — the
# protection that actually caps AI spend if someone hammers the AI routes —
# add a FREE Upstash Redis database (https://upstash.com) and paste its
# REST credentials here. Leave unset to use the in-memory limiter (fine for
# local/dev). No SDK is installed; the limiter calls the Upstash REST API.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-rest-token-here

# ── Global AI spend cap (recommended before ads / growth spikes) ──
# Per-IP rate limits slow ONE abuser; a distributed botnet of many real IPs
# can still run up the AI bill. This is a fleet-wide daily kill-switch: once
# the day's ESTIMATED AI spend reaches this many cents, paid model calls pause
# and routes serve their keyless fallback until the next UTC day. OFF by
# default (unset/0 = no cap, behaviour unchanged). Mirrors VIDEO_STUDIO_MAX_COST_CENTS.
# Set Upstash (above) too so the cap holds across every instance.
# AI_DAILY_BUDGET_CENTS=500   # e.g. 500 = $5.00/day

# ── Admin & Cron Security ────────────────────────────────────
# Required only in production to protect /admin/* pages and the
# /api/research/* endpoints. If left unset in production, those endpoints
# fail closed (return 401) — secure by default.
#
# ADMIN_SECRET: long random string (32+ chars), server-side only.
#   Generate one with: openssl rand -hex 32
# ADMIN_SECRET=change-me-use-openssl-rand-hex-32
#
# ADMIN_EMAILS: comma-separated allowlist of emails that get admin access
#   when SIGNED IN — the friendly way to use /admin/* in production (no
#   header needed; just log in with an allowlisted account). Secure by
#   default: unset/empty = nobody is granted via this path.
# ADMIN_EMAILS=you@example.com
#
# CRON_SECRET: used by Vercel Cron to trigger /api/research/run. Must match
#   the Authorization bearer token configured for the cron in vercel.json.
#   Generate with: openssl rand -hex 32
# CRON_SECRET=change-me-use-openssl-rand-hex-32
#
# AUDIT_ACCESS_TOKEN: turns on read-only external-auditor access at
#   GET /api/audit (a single JSON packet for tools like ChatGPT — verbatim
#   robots.txt + sitemap.xml, the logged-in app surface, analytics overview).
#   OFF by default: unset = the endpoint returns 404. Aggregate/structural
#   data only — never user PII or secrets. Manage at /admin/audit-access.
#   Generate with: openssl rand -hex 32
# AUDIT_ACCESS_TOKEN=change-me-use-openssl-rand-hex-32

# ── Auto-publish social posts (optional, OFF by default) ─────
# The Blog → Social Studio NEVER auto-posts unless you turn this on.
# Master switch — must equal "on" for ANY publishing to happen:
# SOCIAL_AUTOPUBLISH=on
#
# Easiest path (works today, no per-platform OAuth): a webhook you control
# (Zapier / Make / n8n / Buffer) that receives each approved post and posts it.
# SOCIAL_PUBLISH_WEBHOOK_URL=https://hooks.zapier.com/your-hook
#
# OR direct platform APIs — each dormant until its tokens are set:
# LinkedIn (UGC API; token needs w_member_social):
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=urn:li:person:xxxx   # or urn:li:organization:xxxx
# X / Twitter (POST /2/tweets — requires a PAID X API plan):
# X_ACCESS_TOKEN=
# Facebook Page (Graph API; long-lived Page access token):
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_TOKEN=
# Reddit (self post; respect each subreddit's self-promo rules + disclose):
# REDDIT_ACCESS_TOKEN=
# REDDIT_SUBREDDIT=yoursubreddit
# (Instagram, TikTok, YouTube, Threads, Pinterest: route via the webhook relay.)

# ── Research Workflow ────────────────────────────────────────
# Set to "true" to auto-approve low-risk benchmark proposals from research
# runs. Leave "false" to require manual admin review for all proposals.
RESEARCH_AUTO_APPROVE_LOW_RISK=false

# ── AI Operations layer (provider architecture) ──────────────
# Model IDs are config-driven (never hardcoded). EMPTY coach model = use the
# gateway tier default (works today on real keys); set an id to override.
# Keys reuse the ones above: OpenAI=OPENAI_API_KEY, Anthropic=ANTHROPIC_API_KEY,
# Gemini=GOOGLE_AI_API_KEY. Do NOT seed Gemini model ids until validated against
# the connected account (use the admin provider-test).
#
# OpenAI coach (primary user-facing reasoning)
OPENAI_COACH_MODEL=
OPENAI_COACH_FALLBACK_MODEL=
OPENAI_COACH_COST_MODEL=
OPENAI_COACH_TIMEOUT_MS=60000
OPENAI_COACH_MAX_OUTPUT_TOKENS=2500
# Gemini video intake (cloud) — leave model ids empty until validated
GEMINI_VIDEO_FAST_MODEL=
GEMINI_VIDEO_DEEP_MODEL=
GEMINI_VIDEO_FALLBACK_MODEL=
GEMINI_VIDEO_TIMEOUT_MS=120000
GEMINI_VIDEO_MAX_OUTPUT_TOKENS=4000
GEMINI_INLINE_VIDEO_MAX_MB=20
GEMINI_FILE_API_THRESHOLD_MB=20
# Measurement layer (MediaPipe default)
MEASUREMENT_PROVIDER=mediapipe
MEASUREMENT_CONFIDENCE_THRESHOLD=0.65
ENABLE_SERVER_SIDE_MEASUREMENT=true
ENABLE_CLIENT_SIDE_MEASUREMENT=false
# Claude optional premium narrative (DISABLED by default)
ENABLE_CLAUDE_PREMIUM_NARRATIVE=false
CLAUDE_NARRATIVE_MODEL=
CLAUDE_NARRATIVE_TIMEOUT_MS=60000
# General AI system
ENABLE_AI_PROVIDER_ROUTER=true
ENABLE_AI_USAGE_TRACKING=true
ENABLE_AI_ADMIN_CONTROLS=true
ENABLE_AI_EVALS=true
AI_DEFAULT_ANALYSIS_MODE=standard
AI_DEEP_ANALYSIS_MODE=premium
AI_MAX_VIDEO_DURATION_SECONDS=
AI_MAX_VIDEO_FILE_SIZE_MB=
AI_STORE_RAW_PROVIDER_RESPONSES=false
AI_REDACT_PROVIDER_PAYLOADS=true
AI_HUMAN_REVIEW_LOW_CONFIDENCE_THRESHOLD=0.65
