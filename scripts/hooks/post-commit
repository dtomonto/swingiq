#!/bin/sh
# SwingVantage post-commit hook.
#
# After every commit, turn opt-in commit trailers (Update: / Dev-Update:) into
# entries on /updates and /dev-updates, then stage + commit just the two data
# files so they ship with your next push. Installed via `npm run hooks:install`.
#
# Safe by design:
#   - Only commits the two auto-update JSON files (explicit pathspec — never -A).
#   - Never pushes. You push manually, as always.
#   - Never blocks a commit: any failure here exits 0.
#   - Guards against recursion (its own commit does not re-trigger generation).

set -e

# Don't recurse into ourselves: our own publish commit must not re-run this.
last_subject=$(git log -1 --pretty=%s 2>/dev/null || echo "")
case "$last_subject" in
  "chore(updates): publish entries from commit trailers"*) exit 0 ;;
  "chore(social): flag new blog posts for social"*) exit 0 ;;
  "chore(features): refresh feature registry"*) exit 0 ;;
  "chore(setup): refresh setup registry"*) exit 0 ;;
  "chore(audits): refresh audit reports"*) exit 0 ;;
esac
[ -n "$SWINGVANTAGE_UPDATES_HOOK" ] && exit 0
export SWINGVANTAGE_UPDATES_HOOK=1

root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$root" || exit 0

# Generate. If node or the script is unavailable, fail open (never block commits).
node scripts/generate-updates.mjs --quiet || exit 0

files="apps/web/src/data/auto-updates.json apps/web/src/data/auto-dev-updates.json"

# Only commit if the generator actually changed one of the data files.
if ! git diff --quiet -- $files 2>/dev/null; then
  git add -- $files
  git commit -m "chore(updates): publish entries from commit trailers" -- $files || exit 0
  echo "swingvantage: published update entries (see /updates draft + /dev-updates)."
fi

# ── Blog → Social: flag newly-published posts for social generation ──
node scripts/generate-social-queue.mjs --quiet || exit 0
social_file="apps/web/src/data/social-pending.json"
if ! git diff --quiet -- "$social_file" 2>/dev/null; then
  git add -- "$social_file"
  git commit -m "chore(social): flag new blog posts for social" -- "$social_file" || exit 0
  echo "swingvantage: flagged new blog post(s) for social (see /admin/social)."
fi

# ── Registry refreshes (features / setup / audits) — OFF by default ──
# These keep the admin dashboards' committed snapshots current, but they
# regenerated + committed on EVERY commit, which (a) is noisy — up to three
# extra chore commits per commit — and (b) races the JSON files when several
# agents commit at once (leaving merge-conflict markers). They are now opt-in.
# Refresh on demand instead:  npm run features:scan ; npm run setup:scan
# (audits sync via scripts/sync-audit-reports.mjs). A scheduled CI job is the
# recommended long-term home — see docs/ROADMAP.md (#22).
if [ -n "$SWINGVANTAGE_REGISTRY_AUTOCOMMIT" ]; then

# ── Feature Education: detect features and refresh the registry ──
# Keeps the Feature Registry in sync with what shipped so the engine knows
# which features need tutorials / how-tos / videos. Review + generate in
# /admin/feature-education (nothing is published without your approval).
node scripts/scan-features.mjs --quiet || exit 0
registry_file="apps/web/src/data/feature-registry.json"
if ! git diff --quiet -- "$registry_file" 2>/dev/null; then
  git add -- "$registry_file"
  git commit -m "chore(features): refresh feature registry" -- "$registry_file" || exit 0
  echo "swingvantage: refreshed feature registry (see /admin/feature-education)."
fi

# ── Setup hub: auto-discover new database files + `Setup:` trailers ──
# Keeps /admin/setup current so new manual steps appear for the owner without
# anyone remembering to add them. Reviewed (and ticked off) in /admin/setup.
node scripts/scan-setup.mjs --quiet || exit 0
setup_file="apps/web/src/data/setup-registry.json"
if ! git diff --quiet -- "$setup_file" 2>/dev/null; then
  git add -- "$setup_file"
  git commit -m "chore(setup): refresh setup registry" -- "$setup_file" || exit 0
  echo "swingvantage: refreshed setup registry (see /admin/setup)."
fi

# ── Audit Reports: mirror the audit robots' reports into the dashboard ──
# Keeps /admin/audits showing the latest findings from docs/master-audit-report.json
# + docs/audits/* without anyone remembering to sync. Review at /admin/audits.
node scripts/sync-audit-reports.mjs --quiet || exit 0
audits_file="apps/web/src/data/audit-reports.json"
if ! git diff --quiet -- "$audits_file" 2>/dev/null; then
  git add -- "$audits_file"
  git commit -m "chore(audits): refresh audit reports" -- "$audits_file" || exit 0
  echo "swingvantage: refreshed audit reports (see /admin/audits)."
fi

fi  # end SWINGVANTAGE_REGISTRY_AUTOCOMMIT guard

exit 0
